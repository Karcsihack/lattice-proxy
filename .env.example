# Puerto en el que escucha Lattice
LISTEN_ADDR=:8080

# URL base de Ollama (NER local — nunca sale de tu máquina)
OLLAMA_URL=http://localhost:11434

# Modelo Ollama para detección de PII (llama3, phi3, mistral, etc.)
OLLAMA_MODEL=llama3

# URL base de la API upstream (OpenAI o cualquier proveedor compatible)
OPENAI_API_BASE=https://api.openai.com
